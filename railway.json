{
  "$schema": "https://railway.app/schema.json",
  "name": "keyless-sentry",
  "services": {
    "sentry-gateway": {
      "build": {
        "context": ".",
        "dockerfile": "Dockerfile"
      },
      "ports": {
        "18789": {
          "port": 18789,
          "proxy": true
        }
      },
      "environment": [
        "NODE_ENV=production",
        "IS_TEE=false",
        "HEARTBEAT_INTERVAL_MINUTES=30",
        "WORKSPACE_DIR=/app/gateway/src/workspace"
      ],
      "volumes": {
        "/app/gateway/src/workspace": {}
      },
      "deploy": {
        "memory": 512
      }
    }
  },
  "environmentVariables": {
    "KEYLESS_BASE_URL": "",
    "KEYLESS_CHAIN_ID": "",
    "KEYLESS_OWNER": "",
    "ENCRYPTION_KEY": "",
    "SENTRY_REGISTRY_ADDRESS": "",
    "SENTRY_RPC_URL": "",
    "SENTRY_CHAIN_ID": "",
    "WALLETCONNECT_PROJECT_ID": ""
  }
}
