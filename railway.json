{
  "$schema": "https://railway.app/schema.json",
  "name": "bountyclaw",
  "services": {
    "web": {
      "build": {
        "context": ".",
        "dockerfile": "Dockerfile"
      },
      "ports": {
        "3000": {
          "port": 3000,
          "proxy": true
        }
      },
      "environment": [
        "NODE_ENV=production",
        "IS_TEE=false",
        "HEARTBEAT_INTERVAL_MINUTES=30",
        "WORKSPACE_DIR=/app/gateway/src/workspace"
      ],
      "volumes": {
        "/app/gateway/src/workspace": {}
      },
      "deploy": {
        "memory": 1024,
        "numReplicas": 1
      }
    }
  },
  "plugins": {
    "postgres": {
      "plan": "starter"
    }
  },
  "environmentVariables": {
    "KEYLESS_COORDINATOR_URL": {
      "description": "Keyless SDK coordinator URL",
      "value": "https://coordinator.keyless.tech"
    },
    "KEYLESS_CHAIN_ID": {
      "description": "Blockchain chain ID (11142220 = Celo Alfajores, 44787 = Celo Mainnet)",
      "value": "44787"
    },
    "KEYLESS_OWNER": {
      "description": "Owner wallet address that controls the agent"
    },
    "ENCRYPTION_KEY": {
      "description": "64-character hex encryption key for vault"
    },
    "CELO_RPC_URL": {
      "description": "Celo RPC URL",
      "value": "https://rpc.celo.org"
    },
    "CELO_CHAIN_ID": {
      "description": "Celo chain ID",
      "value": "44787"
    },
    "WALLETCONNECT_PROJECT_ID": {
      "description": "WalletConnect project ID"
    },
    "NEXT_PUBLIC_API_URL": {
      "description": "API URL for frontend to connect to",
      "value": "/api"
    }
  }
}
