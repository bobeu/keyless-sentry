generator client {
  provider = "prisma-client-js"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

enum Personality {
  GUARDIAN
  ACCOUNTANT
  STRATEGIST
}

enum TaskEscrowStatus {
  RESERVED
  RELEASED
}

enum AuditLogStatus {
  PENDING
  SUCCESS
  FAILED
}

model User {
  hashedId      String      @id // keccak256 of platform:id
  eoaAddress    String
  walletAddress String?
  personality   Personality
  createdAt     DateTime    @default(now())

  authorizations Authorization[]
  taskEscrows    TaskEscrow[]
  auditLogs      AuditLog[]

  @@map("users")
}

model Authorization {
  id           String   @id @default(uuid())
  userHashedId String
  agentId      String
  signature    String // raw hex signature
  maxSpend     String
  expiresAt    Int // Unix timestamp
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User? @relation(fields: [userHashedId], references: [hashedId], onDelete: Cascade)

  @@index([userHashedId])
  @@index([agentId])
  @@index([userHashedId, agentId, isActive])
  @@map("authorizations")
}

model TaskEscrow {
  taskId       String           @id // PK - taskIdHash
  userHashedId String
  amount       String
  status       TaskEscrowStatus
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user User? @relation(fields: [userHashedId], references: [hashedId], onDelete: Cascade)

  @@index([userHashedId])
  @@index([status])
  @@map("task_escrows")
}

model AuditLog {
  id           String         @id @default(uuid())
  userHashedId String
  action       String
  txHash       String?
  nonce        String? // Transaction nonce for double-spend prevention
  status       AuditLogStatus @default(PENDING)
  gasUsed      String? // Gas used in hex or decimal
  timestamp    DateTime       @default(now())
  details      Json? // Additional metadata (reason for blocking, etc.)

  user User? @relation(fields: [userHashedId], references: [hashedId], onDelete: Cascade)

  @@index([userHashedId])
  @@index([action])
  @@index([timestamp])
  @@index([nonce])
  @@index([status])
  @@map("audit_logs")
}
