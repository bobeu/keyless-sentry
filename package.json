    "react-dom": "^18.3.0",
    "express": "^5.1.0",
    "http-proxy": "^1.18.1",
    "tar": "^7.5.4",
    "viem": "^2.47.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
