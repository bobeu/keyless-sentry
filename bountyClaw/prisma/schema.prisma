generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum BountyStatus {
  OPEN           // Available for agents to take
  IN_PROGRESS    // Agent is working on it
  ESCROWED       // Funds locked in escrow
  PENDING_VERIFICATION // Agent submitted work, waiting for verification
  RELEASED       // Payment released to agent
  CANCELLED      // Cancelled by creator (only when OPEN)
  EXPIRED        // Deadline missed, reopened for other agents
}

enum RegistrationStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}

enum AuditLogStatus {
  PENDING
  SUCCESS
  FAILED
}

enum WalletType {
  USER      // User's personal wallet
  BOUNTY    // Bounty-specific escrow wallet
  AGENT     // Agent wallet
}

enum AgentVerificationStatus {
  PENDING    // Verification in progress
  VERIFIED    // Agent is verified
  REJECTED   // Verification rejected
  SUSPENDED  // Temporarily suspended
}

enum NegotiationStatus {
  PENDING     // Waiting for creator response
  ACCEPTED    // Creator accepted the offer
  REJECTED    // Creator rejected the offer
  EXPIRED     // Negotiation expired (deadline passed)
  WITHDRAWN   // Agent withdrew their offer
}

// ==================== USER & WALLETS ====================

model User {
  hashedId      String     @id // keccak256 of platform:id (wallet address)
  eoaAddress    String     @default("")
  walletAddress String?    // Linked Keyless wallet
  createdAt     DateTime   @default(now())

  bounties      Bounty[]
  auditLogs     AuditLog[]
  wallets       Wallet[]

  // Agent-specific fields
  isAgent       Boolean    @default(false)
  reputation    Int        @default(0)
  agent         Agent?

  @@map("users")
}

model Wallet {
  id          String     @id @default(uuid())
  userId      String?    // Link to User (null for bounty escrow wallets)
  address     String     @unique // Keyless wallet address
  walletType  WalletType
  bountyId    String?    // If BOUNTY type, link to specific bounty
  metadata    Json?      // Additional wallet info from Keyless SDK
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user        User?      @relation(fields: [userId], references: [hashedId], onDelete: SetNull)
  bounties    Bounty[]   @relation("BountyEscrowWallet")

  @@index([userId])
  @@index([walletType])
  @@index([bountyId])
  @@map("wallets")
}

// ==================== AGENTS ====================

model Agent {
  id                    String                  @id @default(uuid())
  walletAddress         String                  @unique // Keyless wallet address
  verificationStatus   AgentVerificationStatus  @default(PENDING)
  reputation            Int                     @default(0)
  capabilities          Json?                   // Agent's capabilities/skills
  metadata              Json?                    // Additional agent info
  registeredAt          DateTime                @default(now())
  lastVerifiedAt        DateTime?
  isActive              Boolean                 @default(true)

  // Reference to User
  userHashId            String                  @unique

  user                  User                    @relation(fields: [userHashId], references: [hashedId], onDelete: Cascade)
  
  // Relations
  negotiations          Negotiation[]
  bounties              Bounty[]                @relation("BountyAgent")
  previousBounties      Bounty[]                @relation("BountyPreviousAgent")
  
  @@index([verificationStatus])
  @@index([reputation])
  @@map("agents")
}

// ==================== AUTHORIZATION SIGNATURES ====================

model Signature {
  id              String   @id @default(uuid())
  walletAddress   String   // The wallet this signature authorizes
  authorization   String   // The signed authorization message
  signedMessage   String   // The actual message that was signed
  expiresAt       DateTime? // Optional expiration
  createdAt       DateTime @default(now())
  isActive        Boolean  @default(true)

  @@index([walletAddress])
  @@index([isActive])
  @@map("signatures")
}

// ==================== TRANSACTIONS ====================

model Transaction {
  id          String   @id @default(uuid())
  bountyId    String?  // Link to bounty (for bounty payouts)
  fromAddress String   // Sender wallet address
  toAddress   String   // Recipient wallet address
  amount      String   // Amount in wei
  currency    String   @default("cUSD") // or "CELO"
  txHash      String?  // Blockchain transaction hash
  status      String   @default("PENDING") // PENDING, CONFIRMED, FAILED
  type        String   // "DEPOSIT", "PAYOUT", "REFUND"
  errorMessage String? // Error message if failed
  createdAt   DateTime @default(now())
  confirmedAt DateTime?

  @@index([bountyId])
  @@index([fromAddress])
  @@index([toAddress])
  @@index([txHash])
  @@map("transactions")
}

// ==================== BOUNTIES ====================

model Bounty {
  id                    String         @id @default(uuid())
  title                 String
  description           String
  rewardAmount          String         // Displayed/minimum reward in wei
  maxRewardAmount       String?        // Maximum reward (if range set)
  currency              String         @default("cUSD")
  
  // Agent assignment
  agentHashId           String?        // Agent currently working on bounty
  previousAgentHashId   String?        // Agent that defaulted (barred from taking again)
  
  status                BountyStatus   @default(OPEN)
  proofUrl              String?        // URL submitted by agent as proof of work
  proofCriteria         String?       // criteria for proving completion
  
  // Capabilities and requirements
  requiredCapabilities  Json?          // Required agent capabilities
  minReputationThreshold Int?          // Minimum reputation required
  
  // Deadline
  completionDeadline    DateTime?      // When work must be completed
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  expiresAt             DateTime?      // Original expiration (for display)
  
  // Escrow
  escrowAddress         String?        // Keyless escrow wallet address for this bounty
  
  // Creator (User who posted bounty)
  creatorHashId         String

  creator               User           @relation(fields: [creatorHashId], references: [hashedId], onDelete: Cascade)
  agent                 Agent?         @relation("BountyAgent", fields: [agentHashId], references: [walletAddress])
  previousAgent          Agent?         @relation("BountyPreviousAgent", fields: [previousAgentHashId], references: [walletAddress])
  escrowWallet           Wallet?        @relation("BountyEscrowWallet", fields: [escrowAddress], references: [address])
  registrations         Registration[]
  negotiations          Negotiation[]

  @@index([creatorHashId])
  @@index([status])
  @@index([agentHashId])
  @@index([previousAgentHashId])
  @@index([completionDeadline])
  @@map("bounties")
}

// ==================== REGISTRATIONS ====================

model Registration {
  id                  String             @id @default(uuid())
  bountyId            String
  hunterAddress       String
  status              RegistrationStatus @default(PENDING)
  proofUrl            String?
  verificationResult  Json?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)

  @@index([bountyId])
  @@index([hunterAddress])
  @@index([status])
  @@map("registrations")
}

// ==================== NEGOTIATIONS ====================

model Negotiation {
  id              String            @id @default(uuid())
  bountyId        String
  agentWallet     String            // Agent's Keyless wallet address
  proposedAmount  String            // Agent's proposed amount in wei
  message         String?           // Agent's message to creator
  status          NegotiationStatus @default(PENDING)
  createdAt       DateTime          @default(now())
  respondedAt     DateTime?
  
  bounty          Bounty            @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  agent           Agent             @relation(fields: [agentWallet], references: [walletAddress])

  @@index([bountyId])
  @@index([agentWallet])
  @@index([status])
  @@map("negotiations")
}

// ==================== AUDIT LOGS ====================

model AuditLog {
  id          String        @id @default(uuid())
  userHashedId String
  action      String
  txHash      String?
  nonce       String?       // Transaction nonce for double-spend prevention
  status      AuditLogStatus @default(PENDING)
  gasUsed     String?       // Gas used in hex or decimal
  timestamp   DateTime      @default(now())
  details     Json?         // Additional metadata

  user User? @relation(fields: [userHashedId], references: [hashedId], onDelete: Cascade)

  @@index([userHashedId])
  @@index([action])
  @@index([timestamp])
  @@index([nonce])
  @@index([status])
  @@map("audit_logs")
}

// ==================== AGENT IDENTITY ====================

/**
 * BountyClaw Identity - Stores the agent's identity
 * This is a singleton record for the BountyClaw agent itself
 */
model BountyClawIdentity {
  id                    String   @id @default(uuid())
  agentName             String
  identityAddress       String   // Agent's Keyless wallet address
  metadataUri           String   // IPFS or data URI with agent capabilities
  a2aEndpoint           String   // Agent-to-Agent endpoint
  chainId               Int      // Chain where identity is registered
  coordinatorUrl        String   // Keyless Coordinator URL
  txHash               String?  // Registration transaction hash
  registeredAt          DateTime @default(now())
  lastVerifiedAt        DateTime @default(now())
  isActive              Boolean  @default(true)

  @@map("bountyclaw_identity")
}
